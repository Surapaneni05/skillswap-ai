# ── Backend ───────────────────────────────────────────────
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/uploads/

# ── IDE ───────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.class

# ── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
