# Root .gitignore for SkillSwap AI

# ── Secrets ──────────────────────────────────────────────
.env
.env.local
.env.production.local
*.key
*.pem

# ── Frontend ──────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
